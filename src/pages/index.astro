---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { velas } from '../data/velas.js';
import { contacto, linkWhatsApp } from '../data/contacto.js';
import { faq } from '../data/faq.js';
import { testimonios } from '../data/testimonios.js';
import fotoHistoria from '../assets/historia.png';

// Enlaces de WhatsApp con mensaje pre-escrito (o #contacto si no hay número)
const waGeneral = linkWhatsApp('Hola Pabilo, me interesan vuestras velas.') ?? '#contacto';
const waContacto = linkWhatsApp('Hola Pabilo, me gustaría hacer un pedido.') ?? '#contacto';
const waMelts = linkWhatsApp('Hola Pabilo, me interesan los wax melts. ¿Qué aromas tenéis?') ?? '#contacto';
const waRegalo = linkWhatsApp('Hola Pabilo, quiero preparar un regalo. ¿Me ayudáis?') ?? '#contacto';
const waVela = (nombre) =>
  linkWhatsApp(`Hola Pabilo, me interesa la vela «${nombre}». ¿Está disponible?`) ?? '#contacto';
---

<Layout>
  <!-- ══════════════ NAV ══════════════ -->
  <nav class="nav">
    <div class="contenedor nav__inner">
      <a href="#top" class="marca" aria-label="Pabilo, inicio">pabilo</a>
      <div class="nav__derecha">
        <ul class="nav__links" aria-label="Principal">
          <li><a href="#coleccion">Colección</a></li>
          <li><a href="#regalo">Regalo</a></li>
          <li><a href="#waxmelts">Wax melts</a></li>
          <li><a href="#faq">FAQ</a></li>
          <li><a href="#contacto">Contacto</a></li>
        </ul>
        <a href={waGeneral} class="pill pill--acento pill--mini" target="_blank" rel="noopener">Pedir</a>
      </div>
    </div>
  </nav>

  <main id="top">
    <!-- ══════════════ HERO ══════════════ -->
    <section class="hero">
      <div class="contenedor hero__grid">
        <div class="hero__texto">
          <div class="kicker">
            <span class="kicker__linea" style="background: var(--acento);"></span>
            <span class="kicker__texto">Velas de autor</span>
          </div>
          <h1 class="hero__titulo">El fuego de los <em>pequeños placeres</em>.</h1>
          <p class="hero__parrafo">
            Velas artesanales en pequeñas tandas, con cera de soja y cristal.
            Hechas a mano, para volver a casa y bajar el ritmo.
          </p>
          <div class="hero__ctas">
            <a href="#coleccion" class="pill pill--oscura">Ver la colección</a>
            <a href="#historia" class="pill pill--borde">Nuestra historia</a>
          </div>
          <div class="microclaims" aria-label="Nuestros compromisos">
            <span>Cera de soja y cristal</span>
            <i aria-hidden="true"></i>
            <span>Tandas pequeñas</span>
            <i aria-hidden="true"></i>
            <span>Hecho a mano en Canarias</span>
          </div>
        </div>

        <!-- La vela encendida, dibujada en CSS -->
        <div class="hero__escena" aria-hidden="true">
          <div class="escena">
            <div class="escena__circulo"></div>
            <div class="velon-zoom">
              <div class="velon">
                <div class="velon__halo"></div>
                <div class="velon__mecha"></div>
                <div class="velon__llama"></div>
                <div class="velon__sombra"></div>
                <div class="velon__tarro">
                  <div class="velon__boca"></div>
                  <div class="velon__etiqueta">
                    <span class="velon__logo">pabilo</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════ 01 · HISTORIA ══════════════ -->
    <section class="seccion" id="historia">
      <div class="contenedor historia__grid">
        <div class="historia__texto">
          <div class="kicker">
            <span class="kicker__num">01</span>
            <span class="kicker__linea"></span>
            <span class="kicker__texto">Nace de una amistad</span>
          </div>
          <h2 class="titulo">Dos manos, una mesa y <em>mucha calma</em>.</h2>
          <p class="parrafo">
            Pabilo empezó como empieza lo bueno: entre dos amigas, una tarde,
            probando ceras en la cocina. Nos gustaba el olor de casa cuando
            todo se apaga y solo queda una luz encendida.
          </p>
          <p class="parrafo">
            Hacemos cada tanda a mano, poca cantidad, sin prisa. Cera natural,
            aromas que reconoces, nada de humo raro. Lo local y lo cercano no
            es una etiqueta: es cómo trabajamos.
          </p>
          <p class="firma">— Claudia &amp; Ana</p>
        </div>
        <div class="historia__foto">
          <div class="placa">
            <Image
              src={fotoHistoria}
              alt="Claudia y Ana rematando a mano una vela Pabilo con flores secas en el taller"
              width={1040}
              quality={80}
            />
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════ 02 · COLECCIÓN (cinta rotatoria) ══════════════ -->
    <section class="seccion" id="coleccion" style="padding-bottom: 90px;">
      <div class="contenedor">
        <div class="coleccion__cabecera">
          <div>
            <div class="kicker">
              <span class="kicker__num">02</span>
              <span class="kicker__linea"></span>
              <span class="kicker__texto">La colección</span>
            </div>
            <h2 class="titulo">Cinco aromas, <em>cinco momentos</em>.</h2>
            <p class="parrafo">
              Cada vela es un lugar y un estado de ánimo. Elige el tuyo o
              regálalo con intención.
            </p>
          </div>
          <div class="flechas">
            <button type="button" class="flecha" data-prev aria-label="Anterior">‹</button>
            <button type="button" class="flecha" data-next aria-label="Siguiente">›</button>
          </div>
        </div>

        <div class="cinta" id="cinta-velas" aria-label="Colección de velas">
          {velas.map((vela) => (
            <article class="tarjeta">
              <div class="tarjeta__escena" aria-hidden="true">
                <div class="tarjeta__circulo" style={`background: ${vela.circulo};`}></div>
                <div class="mini">
                  <div class="mini__mecha"></div>
                  <div class="mini__tarro">
                    <div class="mini__boca"></div>
                    <div class="mini__etiqueta">
                      <span class="mini__logo">pabilo</span>
                      <span class="mini__nombre">{vela.nombre}</span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="tarjeta__cuerpo">
                <div class="tarjeta__tag">{vela.familia}</div>
                <h3 class="tarjeta__nombre">{vela.nombre}</h3>
                <p class="tarjeta__desc">{vela.nota}</p>
                <div class="tarjeta__pie">
                  <span class="tarjeta__precio">{vela.precio} €</span>
                  <span class="tarjeta__horas">{vela.duracion} h aprox.</span>
                </div>
                <a href={waVela(vela.nombre)} class="tarjeta__pedir" target="_blank" rel="noopener">Pedir</a>
              </div>
            </article>
          ))}
        </div>

        <!-- El taller de mezclas -->
        <div class="mezclas" id="aromas">
          <div class="mezclas__intro">
            <div class="mezclas__eyebrow">El taller de mezclas</div>
            <h3 class="mezclas__titulo">¿Y si combinas <em>dos aromas</em>?</h3>
            <p class="mezclas__texto">
              Estas son las mezclas que ya hemos probado en el taller.
              Elige un aroma y su pareja, y te contamos qué nace.
            </p>
          </div>
          <div class="mezclas__panel">
            <div class="mezclas__controles">
              <div class="mezclas__campo">
                <label class="mezclas__label" for="aroma-a">Primer aroma</label>
                <select id="aroma-a">
                  <option value="">Elige un aroma</option>
                </select>
              </div>
              <div class="mezclas__mas" aria-hidden="true">+</div>
              <div class="mezclas__campo">
                <label class="mezclas__label" for="aroma-b">Segundo aroma</label>
                <select id="aroma-b" disabled>
                  <option value="">Combínalo con…</option>
                </select>
              </div>
            </div>
            <div class="mezclas__resultado" id="mezcla-resultado" aria-live="polite">
              <span class="mezclas__pista">Elige un aroma para empezar. ✨</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════ 03 · WAX MELTS ══════════════ -->
    <section class="seccion seccion--arena" id="waxmelts">
      <div class="contenedor wax__grid">
        <div class="wax__intro">
          <div class="kicker">
            <span class="kicker__num">03</span>
            <span class="kicker__linea"></span>
            <span class="kicker__texto">Wax melts</span>
          </div>
          <h2 class="titulo">Aroma <em>sin llama</em>.</h2>
          <p class="parrafo">
            Pequeñas piezas de cera aromática, sin mecha, pensadas solo para
            perfumar. Se derriten poco a poco en un quemador y llenan la casa
            de un aroma intenso y duradero.
          </p>
          <a href={waMelts} class="pill pill--acento" target="_blank" rel="noopener">Pídelos con tu aroma favorito</a>
        </div>
        <div class="wax__filas">
          <div class="wax__fila">
            <h3>Cómo se usan</h3>
            <p>
              Coloca una o varias piezas en tu quemador. El calor las funde despacio
              y liberan su fragancia. Cuando la cera deja de oler, se retira y se
              pone una nueva.
            </p>
          </div>
          <div class="wax__fila">
            <h3>Por qué gustan</h3>
            <p>
              Aromatizan mucho sin llama directa, permiten cambiar de olor con
              facilidad y son una opción práctica y segura para casa o negocio.
            </p>
          </div>
          <div class="wax__fila">
            <h3>¿Vela o wax melt?</h3>
            <p>
              La vela ilumina y perfuma a la vez; el wax melt está pensado solo
              para aromatizar. Por eso no lleva mecha y usa una fuente de calor externa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════ 04 · REGALO ══════════════ -->
    <section class="seccion" id="regalo">
      <div class="contenedor">
        <div class="regalo__cabecera">
          <div class="kicker">
            <span class="kicker__num">04</span>
            <span class="kicker__linea"></span>
            <span class="kicker__texto">Para regalar</span>
          </div>
          <h2 class="titulo">Un detalle que <em>se recuerda</em>.</h2>
          <p class="parrafo">
            Una vela hecha a mano dice más que cualquier cosa comprada con prisa.
            Te ayudamos a que quede perfecto.
          </p>
        </div>
        <div class="regalo__grid">
          <div class="regalo__tarjeta">
            <div class="regalo__icono" aria-hidden="true">✦</div>
            <h3>Packs a medida</h3>
            <p>Eliges los aromas y montamos un pack bonito, listo para regalar sin que tengas que pensar en nada más.</p>
          </div>
          <div class="regalo__tarjeta">
            <div class="regalo__icono" aria-hidden="true">✎</div>
            <h3>Tarjeta con dedicatoria</h3>
            <p>Escribimos tu mensaje a mano en una tarjeta y va dentro del pedido. El detalle que marca la diferencia.</p>
          </div>
          <div class="regalo__tarjeta">
            <div class="regalo__icono" aria-hidden="true">❦</div>
            <h3>Bodas y eventos</h3>
            <p>Detalles para invitados en la cantidad que necesites. Cuéntanos tu idea y te pasamos una propuesta.</p>
          </div>
        </div>
        <div class="regalo__cta">
          <a href={waRegalo} class="pill pill--borde-lleno" target="_blank" rel="noopener">Preparar un regalo</a>
        </div>
      </div>
    </section>

    <!-- ══════════════ DEL TALLER ══════════════ -->
    <section class="taller" id="taller">
      <div class="contenedor">
        <div class="kicker">
          <span class="kicker__linea"></span>
          <span class="kicker__texto">Del taller</span>
        </div>
        <h2 class="titulo">Lo hacemos <em>así</em>.</h2>
        <div class="taller__grid">
          <Image
            class="taller__foto"
            src={fotoHistoria}
            alt="Vela Pabilo con flores secas, hecha a mano en el taller"
            width={720}
            quality={78}
          />
          <div class="taller__mosaico">
            {velas.slice(0, 4).map((v) => (
              <div class="taller__pronto" style={`background: ${v.circulo};`}>pronto</div>
            ))}
          </div>
        </div>
        <p class="taller__nota">Pronto, más fotos reales del taller y de cada vela. 📷</p>
      </div>
    </section>

    <!-- ══════════════ 05 · CÓMO PEDIMOS ══════════════ -->
    <section class="seccion seccion--arena" id="pedidos">
      <div class="contenedor">
        <div class="pedidos__cabecera">
          <div class="kicker">
            <span class="kicker__num">05</span>
            <span class="kicker__linea"></span>
            <span class="kicker__texto">Cómo pedimos</span>
          </div>
          <h2 class="titulo">Hecho a mano significa <em>sin prisa</em>.</h2>
        </div>
        <div class="pasos">
          <div class="paso">
            <div class="paso__num">01</div>
            <h3>Eliges tu vela</h3>
            <p>Nos escribes con el aroma que quieres. Te contamos qué hay listo y qué entra en la próxima tanda.</p>
          </div>
          <div class="paso">
            <div class="paso__num">02</div>
            <h3>La hacemos</h3>
            <p>Vertimos a mano, en pequeña cantidad. Cada vela reposa antes de salir. Eso lleva unos días.</p>
          </div>
          <div class="paso">
            <div class="paso__num">03</div>
            <h3>Llega a casa</h3>
            <p>Envuelta con cuidado, lista para encender o para regalar. Entrega local o envío, como prefieras.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════ 06 · FAQ ══════════════ -->
    <section class="seccion" id="faq">
      <div class="contenedor faq__grid">
        <div class="faq__cabecera">
          <div class="kicker">
            <span class="kicker__num">06</span>
            <span class="kicker__linea"></span>
            <span class="kicker__texto">Preguntas frecuentes</span>
          </div>
          <h2 class="titulo">Lo que suelen <em>preguntarnos</em>.</h2>
        </div>
        <div class="faq__lista">
          {faq.map((item, i) => (
            <details class="faq__item" open={i === 0}>
              <summary>
                <span class="faq__q">{item.pregunta}</span>
                <span class="faq__signo" aria-hidden="true"></span>
              </summary>
              <p class="faq__r">{item.respuesta}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    {/* ══════════════ OPINIONES ══════════════ */}
    {testimonios.length > 0 && (
      <section class="seccion" id="resenas" style="padding-top: 0;">
        <div class="contenedor">
          <div class="opiniones__cabecera">
            <div class="kicker kicker--centro">
              <span class="kicker__linea"></span>
              <span class="kicker__texto">Lo que dicen</span>
              <span class="kicker__linea"></span>
            </div>
            <h2 class="titulo">Cariño que <em>vuelve</em>.</h2>
          </div>
          <div class="opiniones__grid">
            {testimonios.map((t) => (
              <figure class="opinion">
                <div class="opinion__estrellas" aria-label="Cinco estrellas">★★★★★</div>
                <blockquote class="opinion__texto">«{t.texto}»</blockquote>
                <figcaption class="opinion__autor"><strong>{t.autor}</strong> · {t.lugar}</figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ══════════════ 07 · CONTACTO + FOOTER ══════════════ -->
    <section class="contacto" id="contacto">
      <div class="contenedor">
        <div class="contacto__centro">
          <div class="kicker kicker--centro">
            <span class="kicker__num">07</span>
            <span class="kicker__linea"></span>
            <span class="kicker__texto">Hablemos</span>
          </div>
          <h2 class="contacto__titulo">¿Una vela <em>en mente</em>?</h2>
          <p class="contacto__parrafo">
            Escríbenos y la preparamos. Encargos, regalos y detalles para eventos:
            cuéntanos qué buscas y damos con ello.
          </p>
          <div class="contacto__cta">
            <a href={waContacto} class="pill pill--clara" target="_blank" rel="noopener">Escríbenos por WhatsApp</a>
          </div>
          <p class="contacto__lugar">{contacto.ciudad}</p>
        </div>

        <div class="footer__cols">
          <div class="footer__marca">
            <a href="#top" class="marca" aria-label="Pabilo, volver arriba">pabilo</a>
            <p class="footer__desc">
              Velas artesanales en pequeñas tandas, con cera de soja y cristal.
              Hechas a mano en Canarias.
            </p>
          </div>
          <nav aria-label="Enlaces del pie">
            <div class="footer__titulo">Explora</div>
            <div class="footer__lista">
              <a href="#historia">Historia</a>
              <a href="#coleccion">Colección</a>
              <a href="#regalo">Regalo</a>
              <a href="#waxmelts">Wax melts</a>
              <a href="#faq">Preguntas frecuentes</a>
            </div>
          </nav>
          <div>
            <div class="footer__titulo">Contacto</div>
            <div class="footer__lista">
              {linkWhatsApp() && (
                <a href={waGeneral} target="_blank" rel="noopener">WhatsApp</a>
              )}
              {contacto.email && <a href={`mailto:${contacto.email}`}>{contacto.email}</a>}
              {contacto.instagram && (
                <a href={`https://instagram.com/${contacto.instagram}`} target="_blank" rel="noopener">@{contacto.instagram}</a>
              )}
              <span>{contacto.ciudad}</span>
            </div>
          </div>
        </div>

        <div class="footer__base">
          <span class="footer__lema">la elegancia de lo efímero</span>
          <span class="footer__copy">© 2026 Pabilo · Velas de autor</span>
          <span class="footer__credito">
            Web diseñada y desarrollada por
            <a href="https://portafoliowilliam.pages.dev" target="_blank" rel="noopener"> William González</a>
          </span>
        </div>
      </div>
    </section>
  </main>

  <!-- ══════════════ CHAT DE AYUDA (Groq vía /api/chat) ══════════════ -->
  <div class="chat" id="chat">
    <button
      class="chat__boton"
      id="chat-boton"
      type="button"
      aria-expanded="false"
      aria-controls="chat-panel"
      aria-label="Abrir el chat de ayuda"
    >
      <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="8" y="10.5" width="8" height="10" rx="1.8" />
        <path
          class="chat__flama"
          d="M12 3c1.5 1.9 2.2 3.2 2.2 4.3a2.2 2.2 0 1 1-4.4 0C9.8 6.2 10.5 4.9 12 3Z"
          stroke="none"
          style="fill: var(--llama, #CE5B2A);"
        />
      </svg>
    </button>
    <button class="chat__saludo" id="chat-saludo" type="button" hidden>
      ¿Te ayudo a elegir tu vela? 🕯️
    </button>

    <div class="chat__panel" id="chat-panel" role="dialog" aria-label="Chat de ayuda de Pabilo" hidden>
      <div class="chat__cabecera">
        <div>
          <span class="chat__titulo">pabilo</span>
          <span class="chat__sub">tu ayudante de velas</span>
        </div>
        <button class="chat__cerrar" id="chat-cerrar" type="button" aria-label="Cerrar chat">×</button>
      </div>
      <div class="chat__mensajes" id="chat-mensajes" aria-live="polite"></div>
      <div class="chat__chips" id="chat-chips">
        <button type="button" data-chip>¿Cuánto dura una vela?</button>
        <button type="button" data-chip>¿Hacéis envíos?</button>
        <button type="button" data-chip>¿Qué son los wax melts?</button>
      </div>
      <form class="chat__form" id="chat-form">
        <label class="visualmente-oculto" for="chat-input">Tu pregunta</label>
        <input id="chat-input" type="text" placeholder="Escribe tu pregunta…" maxlength="300" autocomplete="off" />
        <button type="submit" class="chat__enviar" aria-label="Enviar mensaje">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M2.7 21.3 22.6 12 2.7 2.7l.05 7.4L17 12 2.75 13.9z"/>
          </svg>
        </button>
      </form>
    </div>
  </div>

  {linkWhatsApp() && (
    <a
      class="wsp-flotante"
      href={waGeneral}
      target="_blank"
      rel="noopener"
      aria-label="Escríbenos por WhatsApp"
    >
      <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" fill="currentColor">
        <path d="M16.001 3C9.373 3 4 8.373 4 15c0 2.1.55 4.152 1.594 5.965L4 29l8.223-1.57A11.94 11.94 0 0 0 16 27c6.627 0 12-5.373 12-12S22.628 3 16.001 3Zm0 21.727c-1.78 0-3.52-.48-5.04-1.386l-.36-.214-4.88.932.93-4.76-.235-.377A9.68 9.68 0 0 1 6.273 15c0-5.36 4.365-9.727 9.728-9.727 5.362 0 9.726 4.367 9.726 9.727 0 5.362-4.364 9.727-9.726 9.727Zm5.34-7.29c-.293-.146-1.73-.853-1.998-.95-.268-.098-.463-.146-.658.147-.195.293-.756.95-.927 1.145-.17.195-.341.22-.634.073-.293-.146-1.237-.456-2.356-1.454-.87-.776-1.458-1.735-1.63-2.028-.17-.293-.018-.451.129-.597.132-.131.293-.341.44-.512.146-.17.195-.293.293-.488.098-.195.049-.366-.024-.512-.073-.146-.658-1.586-.902-2.172-.237-.57-.479-.492-.658-.5l-.561-.01c-.195 0-.512.073-.78.366-.268.293-1.024 1-1.024 2.44 0 1.44 1.049 2.83 1.195 3.026.146.195 2.064 3.152 5.001 4.42.699.302 1.244.482 1.669.617.701.223 1.339.192 1.843.117.562-.084 1.73-.708 1.974-1.39.244-.683.244-1.269.17-1.39-.072-.122-.267-.195-.56-.341Z"/>
      </svg>
    </a>
  )}
</Layout>

<script>
  import { aromas, combinaciones } from '../data/velas.js';
  import { linkWhatsApp } from '../data/contacto.js';

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── La cinta de velas: rota sola, en bucle, como una marquesina ──
  const cinta = document.getElementById('cinta-velas');
  if (cinta) {
    const originales = Array.from(cinta.children);

    // Clonamos el set completo para que el bucle no tenga costuras.
    // Los clones son decorativos: ocultos a lectores y sin foco de teclado.
    originales.forEach((el) => {
      const clon = el.cloneNode(true) as HTMLElement;
      clon.setAttribute('aria-hidden', 'true');
      clon.querySelectorAll('a').forEach((a) => a.setAttribute('tabindex', '-1'));
      cinta.appendChild(clon);
    });

    // Ancho del set original (tarjetas + huecos): donde empieza el clon 1
    let anchoSet = 0;
    const medir = () => {
      const primerClon = cinta.children[originales.length] as HTMLElement | undefined;
      const primero = originales[0] as HTMLElement;
      anchoSet = primerClon ? primerClon.offsetLeft - primero.offsetLeft : 0;
    };
    medir();
    window.addEventListener('resize', medir);

    // Avance automático: suave, pausable, respeta reduced-motion
    let auto = !reduceMotion;
    let reanudarTimer: number | undefined;
    const pausar = () => {
      auto = false;
      if (reanudarTimer) window.clearTimeout(reanudarTimer);
    };
    const reanudar = (ms = 1200) => {
      if (reanudarTimer) window.clearTimeout(reanudarTimer);
      reanudarTimer = window.setTimeout(() => { auto = !reduceMotion; }, ms);
    };

    cinta.addEventListener('pointerenter', pausar);
    cinta.addEventListener('pointerleave', () => reanudar(600));
    cinta.addEventListener('touchstart', pausar, { passive: true });
    cinta.addEventListener('touchend', () => reanudar(2400), { passive: true });
    cinta.addEventListener('focusin', pausar);
    cinta.addEventListener('focusout', () => reanudar(800));

    const VELOCIDAD = 34; // píxeles por segundo — pausado, como una cinta
    let pos = cinta.scrollLeft;
    let anterior = performance.now();
    const bucle = (ahora: number) => {
      const dt = Math.min((ahora - anterior) / 1000, 0.1);
      anterior = ahora;
      // si el usuario ha movido la cinta a mano, nos sincronizamos
      if (Math.abs(cinta.scrollLeft - pos) > 2) pos = cinta.scrollLeft;
      if (auto && anchoSet > 0) {
        pos += VELOCIDAD * dt;
        if (pos >= anchoSet) pos -= anchoSet;
        cinta.scrollLeft = pos;
      }
      requestAnimationFrame(bucle);
    };
    if (!reduceMotion) requestAnimationFrame(bucle);

    // Flechas: saltan una tarjeta y pausan la cinta un momento
    const PASO = 320;
    document.querySelector('[data-prev]')?.addEventListener('click', () => {
      pausar();
      if (cinta.scrollLeft < PASO && anchoSet > 0) cinta.scrollLeft += anchoSet;
      cinta.scrollBy({ left: -PASO, behavior: 'smooth' });
      reanudar(2600);
    });
    document.querySelector('[data-next]')?.addEventListener('click', () => {
      pausar();
      cinta.scrollBy({ left: PASO, behavior: 'smooth' });
      reanudar(2600);
    });
  }

  // ── El taller de mezclas ──
  const selA = document.getElementById('aroma-a') as HTMLSelectElement | null;
  const selB = document.getElementById('aroma-b') as HTMLSelectElement | null;
  const resultado = document.getElementById('mezcla-resultado');

  if (selA && selB && resultado) {
    const lista = [...aromas].sort((a, b) => a.localeCompare(b, 'es'));
    selA.innerHTML =
      '<option value="">Elige un aroma</option>' +
      lista.map((a) => `<option value="${a}">${a}</option>`).join('');

    const claveDe = (a: string, b: string) => [a, b].sort().join('+');
    const probadas = new Map(combinaciones.map((c) => [claveDe(c.par[0], c.par[1]), c]));

    const pintar = () => {
      const a = selA.value;
      const b = selB.value;
      if (!a) {
        resultado.innerHTML = '<span class="mezclas__pista">Elige un aroma para empezar. ✨</span>';
        return;
      }
      if (!b) {
        resultado.innerHTML = '<span class="mezclas__pista">Ahora elige su pareja. ✨</span>';
        return;
      }
      const etiqueta = `${a} + ${b}`;
      const wa =
        linkWhatsApp(`Hola Pabilo, ¿qué nace de la mezcla «${etiqueta}»?`) ?? '#contacto';
      const combo = probadas.get(claveDe(a, b));
      resultado.innerHTML =
        `<span class="mezclas__nombre">«${etiqueta}»</span>` +
        `<span style="color: var(--texto);"> — </span>` +
        `<a href="${wa}" target="_blank" rel="noopener">pregúntanos qué nace →</a>` +
        (combo ? `<p class="mezclas__detalle">${combo.texto}</p>` : '');
    };

    selA.addEventListener('change', () => {
      const a = selA.value;
      selB.innerHTML =
        '<option value="">Combínalo con…</option>' +
        lista.filter((x) => x !== a).map((x) => `<option value="${x}">${x}</option>`).join('');
      selB.disabled = !a;
      pintar();
    });
    selB.addEventListener('change', pintar);
  }

  // ── FAQ: solo una pregunta abierta a la vez ──
  const faqItems = Array.from(document.querySelectorAll('.faq__item')) as HTMLDetailsElement[];
  faqItems.forEach((item) => {
    item.addEventListener('toggle', () => {
      if (item.open) faqItems.forEach((otro) => { if (otro !== item) otro.open = false; });
    });
  });

  // ── Chat de ayuda (habla con /api/chat, que llama a Groq en el servidor) ──
  const chatBoton = document.getElementById('chat-boton');
  const chatPanel = document.getElementById('chat-panel');
  const chatCerrar = document.getElementById('chat-cerrar');
  const chatMensajes = document.getElementById('chat-mensajes');
  const chatChips = document.getElementById('chat-chips');
  const chatForm = document.getElementById('chat-form') as HTMLFormElement | null;
  const chatInput = document.getElementById('chat-input') as HTMLInputElement | null;

  if (chatBoton && chatPanel && chatMensajes && chatForm && chatInput) {
    type Mensaje = { rol: 'usuario' | 'bot'; texto: string };
    const historial: Mensaje[] = [];
    let esperando = false;
    let saludado = false;

    const pintar = (rol: Mensaje['rol'], texto: string) => {
      const burbuja = document.createElement('div');
      burbuja.className = `chat__burbuja chat__burbuja--${rol}`;
      burbuja.textContent = texto;
      chatMensajes.appendChild(burbuja);
      chatMensajes.scrollTop = chatMensajes.scrollHeight;
      return burbuja;
    };

    const abrir = () => {
      chatPanel.hidden = false;
      chatBoton.setAttribute('aria-expanded', 'true');
      if (!saludado) {
        saludado = true;
        const saludo =
          '¡Hola! Soy el ayudante de Pabilo 🕯️ Pregúntame por las velas, los aromas, los wax melts o los envíos.';
        historial.push({ rol: 'bot', texto: saludo });
        pintar('bot', saludo);
      }
      chatInput.focus();
    };
    const cerrar = () => {
      chatPanel.hidden = true;
      chatBoton.setAttribute('aria-expanded', 'false');
    };

    chatBoton.addEventListener('click', () => (chatPanel.hidden ? abrir() : cerrar()));
    chatCerrar?.addEventListener('click', cerrar);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !chatPanel.hidden) cerrar();
    });

    // Burbujita de saludo: aparece a los segundos, una vez por sesión
    const saludoBurbuja = document.getElementById('chat-saludo');
    const YA_SALUDADO = 'pabilo-chat-saludado';
    const ocultarSaludo = () => saludoBurbuja?.setAttribute('hidden', '');
    if (saludoBurbuja && !sessionStorage.getItem(YA_SALUDADO)) {
      window.setTimeout(() => {
        if (chatPanel.hidden && !sessionStorage.getItem(YA_SALUDADO)) {
          saludoBurbuja.hidden = false;
          sessionStorage.setItem(YA_SALUDADO, '1');
          window.setTimeout(ocultarSaludo, 14000);
        }
      }, 6000);
      saludoBurbuja.addEventListener('click', () => {
        ocultarSaludo();
        abrir();
      });
    }
    chatBoton.addEventListener('click', ocultarSaludo);

    const enviar = async (texto: string) => {
      const limpio = texto.trim();
      if (!limpio || esperando) return;
      esperando = true;
      historial.push({ rol: 'usuario', texto: limpio });
      pintar('usuario', limpio);
      chatInput.value = '';
      chatChips?.setAttribute('hidden', '');

      const escribiendo = pintar('bot', '…');
      escribiendo.classList.add('chat__burbuja--escribiendo');

      try {
        const r = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mensajes: historial.slice(-8) }),
        });
        if (!r.ok) throw new Error('respuesta no ok');
        const datos = await r.json();
        const respuesta =
          typeof datos.respuesta === 'string' && datos.respuesta
            ? datos.respuesta
            : 'No te he entendido bien, ¿me lo preguntas de otra forma?';
        historial.push({ rol: 'bot', texto: respuesta });
        escribiendo.classList.remove('chat__burbuja--escribiendo');
        escribiendo.textContent = respuesta;
      } catch {
        escribiendo.classList.remove('chat__burbuja--escribiendo');
        escribiendo.textContent =
          'Ahora mismo no puedo responder 😅 Escríbenos por WhatsApp (el botón verde) y te atendemos al momento.';
      } finally {
        esperando = false;
        chatMensajes.scrollTop = chatMensajes.scrollHeight;
      }
    };

    chatForm.addEventListener('submit', (e) => {
      e.preventDefault();
      enviar(chatInput.value);
    });
    chatChips?.querySelectorAll('[data-chip]').forEach((chip) => {
      chip.addEventListener('click', () => enviar(chip.textContent || ''));
    });
  }
</script>
