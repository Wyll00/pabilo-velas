---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import { velas, combinaciones } from '../data/velas.js';
import { contacto, linkWhatsApp } from '../data/contacto.js';
import { faq } from '../data/faq.js';
import { testimonios } from '../data/testimonios.js';
import fotoHistoria from '../assets/historia.png';

// Solo se pueden mezclar aromas con combinación probada (con descripción)
const aromasCombinables = [...new Set(combinaciones.flatMap((c) => c.par))].sort((a, b) =>
  a.localeCompare(b, 'es')
);

// Enlaces de WhatsApp con mensaje pre-escrito (o #contacto si no hay número)
const waGeneral = linkWhatsApp('Hola Pabilo, me interesan vuestras velas.') ?? '#contacto';
const waWax = linkWhatsApp('Hola Pabilo, me interesan los wax melts. ¿Qué aromas tenéis?') ?? '#contacto';
const waRegalo = linkWhatsApp('Hola Pabilo, quiero preparar un regalo. ¿Me ayudáis?') ?? '#contacto';
const waVela = (nombre) =>
  linkWhatsApp(`Hola Pabilo, me interesa la vela «${nombre}». ¿Está disponible?`) ?? '#contacto';
---

<Layout>
  <!-- ══════════════ NAV ══════════════ -->
  <header class="nav" id="nav">
    <div class="contenedor nav__inner">
      <a href="#top" class="marca" aria-label="Pabilo, inicio">
        pabilo<span class="marca__punto" aria-hidden="true"></span>
      </a>
      <div class="nav__derecha">
        <nav aria-label="Principal">
          <ul class="nav__links">
            <li><a href="#coleccion">Colección</a></li>
            <li><a href="#regalo">Regalo</a></li>
            <li><a href="#waxmelts">Wax melts</a></li>
            <li><a href="#faq">FAQ</a></li>
            <li><a href="#contacto">Contacto</a></li>
          </ul>
        </nav>
        <a href={waGeneral} class="btn btn--mini" target="_blank" rel="noopener">Pedir</a>
      </div>
    </div>
  </header>

  <div class="luz-vela" id="luz-vela" aria-hidden="true"></div>

  <main id="top">
    <!-- ══════════════ HERO ══════════════ -->
    <section class="hero">
      <div class="contenedor">
        <div class="mecha" aria-hidden="true">
          <span class="llama"></span>
          <span class="hilo"></span>
          <span class="vaso"></span>
        </div>
        <h1 class="hero__eslogan">El fuego de los pequeños placeres.</h1>
        <p class="hero__intro">
          Velas artesanales en pequeñas tandas, con cera de soja y cristal.
          Hechas a mano, para volver a casa y bajar el ritmo.
        </p>
        <div class="hero__cta">
          <a href="#coleccion" class="btn">Ver la colección</a>
          <a href="#historia" class="btn btn--linea">Nuestra historia</a>
        </div>
        <div class="confianza" aria-label="Nuestros compromisos">
          <span>Cera de soja y cristal</span>
          <span>Tandas pequeñas</span>
          <span>Hecho a mano en Canarias</span>
        </div>
      </div>
    </section>

    <div class="mecha-divisor" aria-hidden="true"></div>

    <!-- ══════════════ HISTORIA ══════════════ -->
    <section class="seccion" id="historia">
      <div class="contenedor">
        <div class="historia__grid">
          <div class="historia__texto reveal">
            <p class="eyebrow"><span class="eyebrow__num">01</span>Nace de una amistad</p>
            <h2 class="titulo">Dos manos, una mesa<br />y mucha calma.</h2>
            <p>
              Pabilo empezó como empieza lo bueno: entre dos amigas, una tarde,
              probando ceras en la cocina. Nos gustaba el olor de casa cuando
              todo se apaga y solo queda una luz encendida.
            </p>
            <p>
              Hacemos cada tanda a mano, poca cantidad, sin prisa. Cera natural,
              aromas que reconoces, nada de humo raro. Lo local y lo cercano no
              es una etiqueta: es cómo trabajamos.
            </p>
            <p class="firma">— Claudia &amp; Ana</p>
          </div>
          <figure class="retrato reveal">
            <Image
              src={fotoHistoria}
              alt="Claudia y Ana rematando a mano una vela Pabilo con flores secas en el taller"
              width={1040}
              quality={80}
            />
          </figure>
        </div>
      </div>
    </section>

    <div class="mecha-divisor" aria-hidden="true"></div>

    <!-- ══════════════ COLECCIÓN ══════════════ -->
    <section class="seccion" id="coleccion">
      <div class="contenedor">
        <div class="coleccion__cabecera reveal">
          <p class="eyebrow"><span class="eyebrow__num">02</span>La colección</p>
          <h2 class="titulo">Cinco aromas,<br />cinco momentos.</h2>
          <p>
            Cada vela es <span class="sensorial">un lugar y un estado de ánimo</span>.
            Elige el tuyo o regálalo con intención.
          </p>
        </div>

        <div class="carrusel reveal" id="carrusel-velas">
          <button class="carrusel__flecha carrusel__flecha--prev" type="button" data-prev aria-label="Vela anterior">‹</button>
          <div class="carrusel__ventana">
            <ul class="carrusel__pista" data-pista>
              {velas.map((vela) => (
                <li class="carrusel__slide" aria-roledescription="Vela">
                  <article class="showcase">
                    <div
                      class="showcase__foto"
                      style={`background: linear-gradient(150deg, ${vela.tono[0]}, ${vela.tono[1]});`}
                    >
                      <div class="vela__etiqueta">
                        <span class="marca">pabilo</span>
                        <span class="llama-min" aria-hidden="true"></span>
                        <span style="font-size:0.6rem; letter-spacing:0.12em; color:var(--ceniza); text-transform:uppercase;">
                          {vela.nombre}
                        </span>
                      </div>
                    </div>
                    <div class="showcase__cuerpo">
                      <span class="vela__familia">{vela.familia}</span>
                      <h3 class="showcase__nombre">{vela.nombre}</h3>
                      <p class="vela__nota">{vela.nota}</p>
                      <div class="showcase__pie">
                        <span class="vela__precio">
                          {vela.precio} €
                          <small>{vela.duracion} h aprox.</small>
                        </span>
                        <a href={waVela(vela.nombre)} class="btn btn--linea" target="_blank" rel="noopener">Pedir</a>
                      </div>
                    </div>
                  </article>
                </li>
              ))}
            </ul>
          </div>
          <button class="carrusel__flecha carrusel__flecha--next" type="button" data-next aria-label="Vela siguiente">›</button>
          <div class="carrusel__dots" data-dots role="tablist" aria-label="Elegir vela">
            {velas.map((vela, i) => (
              <button
                class="carrusel__dot"
                type="button"
                data-dot
                role="tab"
                aria-label={vela.nombre}
                aria-selected={i === 0 ? 'true' : 'false'}
              ></button>
            ))}
          </div>
        </div>

        <!-- El mezclador: combina dos aromas y mira qué nace -->
        <div class="mezclador reveal" id="aromas">
          <p class="eyebrow" style="justify-content:center;">El taller de mezclas</p>
          <h3 class="mezclador__titulo">¿Y si combinas dos aromas?</h3>
          <p class="mezclador__intro">
            Estas son las mezclas que ya hemos probado en el taller.
            Elige un aroma y su pareja, y te contamos qué nace.
          </p>
          <div class="mezclador__controles">
            <label class="visualmente-oculto" for="aroma-a">Primer aroma</label>
            <select id="aroma-a">
              <option value="">Elige un aroma</option>
              {aromasCombinables.map((a) => <option value={a}>{a}</option>)}
            </select>
            <span class="mezclador__mas" aria-hidden="true">+</span>
            <label class="visualmente-oculto" for="aroma-b">Segundo aroma</label>
            <select id="aroma-b" disabled>
              <option value="">Combínalo con…</option>
            </select>
          </div>
          <div class="mezclador__resultado" id="mezcla-resultado" aria-live="polite">
            <p class="mezclador__pista">Elige un aroma para empezar. ✨</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════ WAX MELTS ══════════════ -->
    <section class="seccion" id="waxmelts">
      <div class="contenedor">
        <div class="coleccion__cabecera reveal">
          <p class="eyebrow" style="justify-content:center;"><span class="eyebrow__num">03</span>Wax melts</p>
          <h2 class="titulo">Aroma sin llama.</h2>
          <p>
            Pequeñas piezas de cera aromática, <span class="sensorial">sin mecha</span>,
            pensadas solo para perfumar. Se derriten poco a poco en un quemador
            y llenan la casa de un aroma intenso y duradero.
          </p>
        </div>
        <div class="wax__grid">
          <div class="wax__item reveal">
            <h3>Cómo se usan</h3>
            <p>
              Coloca una o varias piezas en tu quemador. El calor las funde despacio
              y liberan su fragancia. Cuando la cera deja de oler, se retira y se
              pone una nueva.
            </p>
          </div>
          <div class="wax__item reveal">
            <h3>Por qué gustan</h3>
            <p>
              Aromatizan mucho sin llama directa, permiten cambiar de olor con
              facilidad y son una opción práctica y segura para casa o negocio.
            </p>
          </div>
          <div class="wax__item reveal">
            <h3>¿Vela o wax melt?</h3>
            <p>
              La vela ilumina y perfuma a la vez; el wax melt está pensado solo
              para aromatizar. Por eso no lleva mecha y usa una fuente de calor externa.
            </p>
          </div>
        </div>
        <div class="wax__cta reveal">
          <a href={waWax} class="btn btn--linea" target="_blank" rel="noopener">Pídelos con tu aroma favorito</a>
        </div>
      </div>
    </section>

    <!-- ══════════════ REGALO ══════════════ -->
    <section class="seccion" id="regalo">
      <div class="contenedor">
        <div class="coleccion__cabecera reveal">
          <p class="eyebrow" style="justify-content:center;"><span class="eyebrow__num">04</span>Para regalar</p>
          <h2 class="titulo">Un detalle que se recuerda.</h2>
          <p>
            Una vela hecha a mano dice más que cualquier cosa comprada con prisa.
            Te ayudamos a que <span class="sensorial">quede perfecto</span>.
          </p>
        </div>
        <div class="regalo__grid">
          <div class="regalo__item reveal">
            <div class="regalo__icono" aria-hidden="true">✦</div>
            <h3>Packs a medida</h3>
            <p>Eliges los aromas y montamos un pack bonito, listo para regalar sin que tengas que pensar en nada más.</p>
          </div>
          <div class="regalo__item reveal">
            <div class="regalo__icono" aria-hidden="true">✎</div>
            <h3>Tarjeta con dedicatoria</h3>
            <p>Escribimos tu mensaje a mano en una tarjeta y va dentro del pedido. El detalle que marca la diferencia.</p>
          </div>
          <div class="regalo__item reveal">
            <div class="regalo__icono" aria-hidden="true">❦</div>
            <h3>Bodas y eventos</h3>
            <p>Detalles para invitados en la cantidad que necesites. Cuéntanos tu idea y te pasamos una propuesta.</p>
          </div>
        </div>
        <div class="regalo__cta reveal">
          <a href={waRegalo} class="btn" target="_blank" rel="noopener">Preparar un regalo</a>
        </div>
      </div>
    </section>

    <!-- ══════════════ PROCESO ══════════════ -->
    <section class="seccion proceso" id="proceso">
      <div class="contenedor">
        <div class="proceso__cabecera">
          <div class="reveal" style="max-width: 46ch;">
            <p class="eyebrow"><span class="eyebrow__num">05</span>Cómo pedimos</p>
            <h2 class="titulo">Hecho a mano<br />significa <span class="sensorial">sin prisa</span>.</h2>
          </div>
          <div class="sello reveal" role="img" aria-label="Sello Pabilo — velas de autor">
            <span class="sello__nombre">pabilo</span>
            <span class="sello__division" aria-hidden="true"></span>
            <span class="sello__lema">velas de autor</span>
          </div>
        </div>
        <div class="pasos">
          <div class="paso reveal">
            <div class="paso__num">01</div>
            <h3>Eliges tu vela</h3>
            <p>Nos escribes con el aroma que quieres. Te contamos qué hay listo y qué entra en la próxima tanda.</p>
          </div>
          <div class="paso reveal">
            <div class="paso__num">02</div>
            <h3>La hacemos</h3>
            <p>Vertimos a mano, en pequeña cantidad. Cada vela reposa antes de salir. Eso lleva unos días.</p>
          </div>
          <div class="paso reveal">
            <div class="paso__num">03</div>
            <h3>Llega a casa</h3>
            <p>Envuelta con cuidado, lista para encender o para regalar. Entrega local o envío, como prefieras.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════ FAQ ══════════════ -->
    <section class="seccion" id="faq">
      <div class="contenedor">
        <div class="coleccion__cabecera reveal">
          <p class="eyebrow" style="justify-content:center;"><span class="eyebrow__num">06</span>Preguntas frecuentes</p>
          <h2 class="titulo">Lo que suelen preguntarnos.</h2>
        </div>
        <div class="faq reveal">
          {faq.map((item) => (
            <details class="faq__item">
              <summary>{item.pregunta}</summary>
              <p class="faq__respuesta">{item.respuesta}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    {/* ══════════════ RESEÑAS ══════════════ */}
    {testimonios.length > 0 && (
      <section class="seccion resenas" id="resenas">
        <div class="contenedor">
          <div class="coleccion__cabecera reveal">
            <p class="eyebrow" style="justify-content:center;">Lo que dicen</p>
            <h2 class="titulo">Cariño que vuelve.</h2>
          </div>
          <div class="resenas__grid">
            {testimonios.map((t) => (
              <figure class="resena reveal">
                <div class="resena__estrellas" aria-label="Cinco estrellas">★★★★★</div>
                <blockquote class="resena__texto">«{t.texto}»</blockquote>
                <figcaption class="resena__autor">{t.autor} · {t.lugar}</figcaption>
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ══════════════ CONTACTO (datos en blanco) ══════════════ -->
    <section class="seccion contacto" id="contacto">
      <div class="contenedor">
        <div class="contacto__caja reveal">
          <p class="eyebrow" style="justify-content:center;"><span class="eyebrow__num">07</span>Hablemos</p>
          <h2 class="titulo">¿Una vela en mente?</h2>
          <p>
            Escríbenos y la preparamos. Encargos, regalos y detalles para eventos:
            cuéntanos qué buscas y damos con ello.
          </p>
          <div class="contacto__acciones">
            {linkWhatsApp('Hola Pabilo, me gustaría hacer un pedido.') && (
              <a href={linkWhatsApp('Hola Pabilo, me gustaría hacer un pedido.')} class="btn" target="_blank" rel="noopener">
                Escríbenos por WhatsApp
              </a>
            )}
            {contacto.email && (
              <a href={`mailto:${contacto.email}`} class="btn btn--linea">Enviar un email</a>
            )}
          </div>
          <p class="contacto__redes">
            {contacto.instagram && (
              <>
                <a href={`https://instagram.com/${contacto.instagram}`} target="_blank" rel="noopener">@{contacto.instagram}</a>
                <span aria-hidden="true"> · </span>
              </>
            )}
            {contacto.ciudad}
          </p>
        </div>
      </div>
    </section>

    <!-- ══════════════ FOOTER ══════════════ -->
    <footer class="footer">
      <div class="contenedor">
        <div class="footer__grid">
          <div>
            <a href="#top" class="marca" aria-label="Pabilo, volver arriba">
              pabilo<span class="marca__punto" aria-hidden="true"></span>
            </a>
            <p class="footer__desc">
              Velas de autor hechas a mano en Canarias.
              El fuego de los pequeños placeres.
            </p>
          </div>
          <nav aria-label="Enlaces del pie">
            <p class="footer__titulo">Explora</p>
            <ul class="footer__lista">
              <li><a href="#historia">Historia</a></li>
              <li><a href="#coleccion">Colección</a></li>
              <li><a href="#regalo">Regalo</a></li>
              <li><a href="#waxmelts">Wax melts</a></li>
              <li><a href="#faq">Preguntas frecuentes</a></li>
              <li><a href="#contacto">Contacto</a></li>
            </ul>
          </nav>
          <div>
            <p class="footer__titulo">Contacto</p>
            <ul class="footer__lista">
              {linkWhatsApp() && (
                <li><a href={linkWhatsApp('Hola Pabilo, me interesan vuestras velas.')} target="_blank" rel="noopener">WhatsApp</a></li>
              )}
              {contacto.email && (
                <li><a href={`mailto:${contacto.email}`}>{contacto.email}</a></li>
              )}
              {contacto.instagram && (
                <li><a href={`https://instagram.com/${contacto.instagram}`} target="_blank" rel="noopener">@{contacto.instagram}</a></li>
              )}
              <li><span>{contacto.ciudad}</span></li>
            </ul>
          </div>
        </div>
        <div class="footer__base">
          <div class="footer__divisor" aria-hidden="true"><span></span></div>
          <p class="footer__lema">la elegancia de lo efímero</p>
          <p class="footer__copy">© 2026 Pabilo · Velas de autor</p>
          <p class="footer__credito">
            Web diseñada y desarrollada por
            <a href="https://portafoliowilliam.pages.dev" target="_blank" rel="noopener">William González</a>
          </p>
        </div>
      </div>
    </footer>
  </main>

  <!-- ══════════════ CHAT DE AYUDA (Groq vía /api/chat) ══════════════ -->
  <div class="chat" id="chat">
    <button
      class="chat__boton"
      id="chat-boton"
      type="button"
      aria-expanded="false"
      aria-controls="chat-panel"
      aria-label="Abrir el chat de ayuda"
    >
      <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="8" y="10.5" width="8" height="10" rx="1.8" />
        <path
          class="chat__flama"
          d="M12 3c1.5 1.9 2.2 3.2 2.2 4.3a2.2 2.2 0 1 1-4.4 0C9.8 6.2 10.5 4.9 12 3Z"
          stroke="none"
          style="fill: var(--ambar, #CE8E44);"
        />
      </svg>
    </button>
    <button class="chat__saludo" id="chat-saludo" type="button" hidden>
      ¿Te ayudo a elegir tu vela? 🕯️
    </button>

    <div class="chat__panel" id="chat-panel" role="dialog" aria-label="Chat de ayuda de Pabilo" hidden>
      <div class="chat__cabecera">
        <div>
          <span class="chat__titulo">pabilo<span class="chat__punto" aria-hidden="true"></span></span>
          <span class="chat__sub">tu ayudante de velas</span>
        </div>
        <button class="chat__cerrar" id="chat-cerrar" type="button" aria-label="Cerrar chat">×</button>
      </div>
      <div class="chat__mensajes" id="chat-mensajes" aria-live="polite"></div>
      <div class="chat__chips" id="chat-chips">
        <button type="button" data-chip>¿Cuánto dura una vela?</button>
        <button type="button" data-chip>¿Hacéis envíos?</button>
        <button type="button" data-chip>¿Qué son los wax melts?</button>
      </div>
      <form class="chat__form" id="chat-form">
        <label class="visualmente-oculto" for="chat-input">Tu pregunta</label>
        <input id="chat-input" type="text" placeholder="Escribe tu pregunta…" maxlength="300" autocomplete="off" />
        <button type="submit" class="chat__enviar" aria-label="Enviar mensaje">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M2.7 21.3 22.6 12 2.7 2.7l.05 7.4L17 12 2.75 13.9z"/>
          </svg>
        </button>
      </form>
    </div>
  </div>

  {linkWhatsApp() && (
    <a
      class="wsp-flotante"
      href={linkWhatsApp('Hola Pabilo, me interesan vuestras velas.')}
      target="_blank"
      rel="noopener"
      aria-label="Escríbenos por WhatsApp"
    >
      <svg viewBox="0 0 32 32" width="28" height="28" aria-hidden="true" fill="currentColor">
        <path d="M16.001 3C9.373 3 4 8.373 4 15c0 2.1.55 4.152 1.594 5.965L4 29l8.223-1.57A11.94 11.94 0 0 0 16 27c6.627 0 12-5.373 12-12S22.628 3 16.001 3Zm0 21.727c-1.78 0-3.52-.48-5.04-1.386l-.36-.214-4.88.932.93-4.76-.235-.377A9.68 9.68 0 0 1 6.273 15c0-5.36 4.365-9.727 9.728-9.727 5.362 0 9.726 4.367 9.726 9.727 0 5.362-4.364 9.727-9.726 9.727Zm5.34-7.29c-.293-.146-1.73-.853-1.998-.95-.268-.098-.463-.146-.658.147-.195.293-.756.95-.927 1.145-.17.195-.341.22-.634.073-.293-.146-1.237-.456-2.356-1.454-.87-.776-1.458-1.735-1.63-2.028-.17-.293-.018-.451.129-.597.132-.131.293-.341.44-.512.146-.17.195-.293.293-.488.098-.195.049-.366-.024-.512-.073-.146-.658-1.586-.902-2.172-.237-.57-.479-.492-.658-.5l-.561-.01c-.195 0-.512.073-.78.366-.268.293-1.024 1-1.024 2.44 0 1.44 1.049 2.83 1.195 3.026.146.195 2.064 3.152 5.001 4.42.699.302 1.244.482 1.669.617.701.223 1.339.192 1.843.117.562-.084 1.73-.708 1.974-1.39.244-.683.244-1.269.17-1.39-.072-.122-.267-.195-.56-.341Z"/>
      </svg>
    </a>
  )}
</Layout>

<script>
  import { combinaciones } from '../data/velas.js';

  // ── El mezclador de aromas ──
  // Solo se ofrecen las mezclas probadas: al elegir el primer aroma,
  // el segundo desplegable se filtra a sus parejas con descripción.
  const selA = document.getElementById('aroma-a') as HTMLSelectElement | null;
  const selB = document.getElementById('aroma-b') as HTMLSelectElement | null;
  const resultado = document.getElementById('mezcla-resultado');

  const claveDe = (a: string, b: string) => [a, b].sort().join('+');
  const mezclas = new Map(combinaciones.map((c) => [claveDe(c.par[0], c.par[1]), c]));

  // aroma → lista de parejas probadas
  const parejas = new Map<string, string[]>();
  combinaciones.forEach(({ par: [x, y] }) => {
    parejas.set(x, [...(parejas.get(x) ?? []), y]);
    parejas.set(y, [...(parejas.get(y) ?? []), x]);
  });

  function pintarMezcla() {
    if (!selA || !selB || !resultado) return;
    const a = selA.value;
    const b = selB.value;

    if (!a) {
      resultado.innerHTML = '<p class="mezclador__pista">Elige un aroma para empezar. ✨</p>';
      return;
    }
    if (!b) {
      resultado.innerHTML = '<p class="mezclador__pista">Ahora elige su pareja. ✨</p>';
      return;
    }
    const mezcla = mezclas.get(claveDe(a, b));
    if (!mezcla) return;
    resultado.innerHTML = `
      <h4>${mezcla.titulo}</h4>
      <p>${mezcla.texto}</p>`;
  }

  function actualizarParejas() {
    if (!selA || !selB) return;
    const a = selA.value;
    const anterior = selB.value;
    const opciones = (parejas.get(a) ?? []).sort((x, y) => x.localeCompare(y, 'es'));

    selB.innerHTML = '<option value="">Combínalo con…</option>' +
      opciones.map((o) => `<option value="${o}">${o}</option>`).join('');
    selB.disabled = !a;

    // si solo hay una pareja posible, la elegimos por él
    if (opciones.length === 1) selB.value = opciones[0];
    else if (opciones.includes(anterior)) selB.value = anterior;

    pintarMezcla();
  }

  selA?.addEventListener('change', actualizarParejas);
  selB?.addEventListener('change', pintarMezcla);

  // ── Luz de vela que sigue al ratón ──
  // Solo en dispositivos con puntero fino (en móvil no hay cursor).
  const luz = document.getElementById('luz-vela');
  if (luz && window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
    let destinoX = window.innerWidth / 2;
    let destinoY = window.innerHeight * 0.35;
    let lx = destinoX;
    let ly = destinoY;
    let encendida = false;

    window.addEventListener(
      'pointermove',
      (e) => {
        destinoX = e.clientX;
        destinoY = e.clientY;
        if (!encendida) {
          encendida = true;
          lx = destinoX;
          ly = destinoY;
          luz.classList.add('encendida');
        }
      },
      { passive: true }
    );

    // La luz persigue al cursor con un poco de pereza, como una llama
    (function bucleLuz() {
      lx += (destinoX - lx) * 0.14;
      ly += (destinoY - ly) * 0.14;
      luz.style.setProperty('--luz-x', lx.toFixed(1) + 'px');
      luz.style.setProperty('--luz-y', ly.toFixed(1) + 'px');
      requestAnimationFrame(bucleLuz);
    })();
  }

  // ── Carrusel de velas (auto-avance cada 4 s, con fundido suave) ──
  const carrusel = document.getElementById('carrusel-velas');
  if (carrusel) {
    const slides = Array.from(carrusel.querySelectorAll('.carrusel__slide'));
    const dots = Array.from(carrusel.querySelectorAll('[data-dot]'));
    const total = slides.length;
    let indice = 0;
    let timer: number | undefined;

    const mostrar = (i: number) => {
      indice = (i + total) % total;
      slides.forEach((s, j) => s.classList.toggle('activa', j === indice));
      dots.forEach((d, j) => d.setAttribute('aria-selected', j === indice ? 'true' : 'false'));
    };
    const siguiente = () => mostrar(indice + 1);

    const arrancar = () => {
      if (total <= 1) return;
      detener();
      timer = window.setInterval(siguiente, 4000);
    };
    const detener = () => { if (timer) window.clearInterval(timer); timer = undefined; };

    carrusel.querySelector('[data-next]')?.addEventListener('click', () => { siguiente(); arrancar(); });
    carrusel.querySelector('[data-prev]')?.addEventListener('click', () => { mostrar(indice - 1); arrancar(); });
    dots.forEach((d, j) => d.addEventListener('click', () => { mostrar(j); arrancar(); }));

    // Pausa al pasar el ratón o al enfocar con teclado
    carrusel.addEventListener('mouseenter', detener);
    carrusel.addEventListener('mouseleave', arrancar);
    carrusel.addEventListener('focusin', detener);
    carrusel.addEventListener('focusout', arrancar);

    mostrar(0);
    arrancar();
  }

  // ── Chat de ayuda (habla con /api/chat, que llama a Groq en el servidor) ──
  const chatBoton = document.getElementById('chat-boton');
  const chatPanel = document.getElementById('chat-panel');
  const chatCerrar = document.getElementById('chat-cerrar');
  const chatMensajes = document.getElementById('chat-mensajes');
  const chatChips = document.getElementById('chat-chips');
  const chatForm = document.getElementById('chat-form') as HTMLFormElement | null;
  const chatInput = document.getElementById('chat-input') as HTMLInputElement | null;

  if (chatBoton && chatPanel && chatMensajes && chatForm && chatInput) {
    type Mensaje = { rol: 'usuario' | 'bot'; texto: string };
    const historial: Mensaje[] = [];
    let esperando = false;
    let saludado = false;

    const pintar = (rol: Mensaje['rol'], texto: string) => {
      const burbuja = document.createElement('div');
      burbuja.className = `chat__burbuja chat__burbuja--${rol}`;
      burbuja.textContent = texto;
      chatMensajes.appendChild(burbuja);
      chatMensajes.scrollTop = chatMensajes.scrollHeight;
      return burbuja;
    };

    const abrir = () => {
      chatPanel.hidden = false;
      chatBoton.setAttribute('aria-expanded', 'true');
      if (!saludado) {
        saludado = true;
        const saludo =
          '¡Hola! Soy el ayudante de Pabilo 🕯️ Pregúntame por las velas, los aromas, los wax melts o los envíos.';
        historial.push({ rol: 'bot', texto: saludo });
        pintar('bot', saludo);
      }
      chatInput.focus();
    };
    const cerrar = () => {
      chatPanel.hidden = true;
      chatBoton.setAttribute('aria-expanded', 'false');
    };

    chatBoton.addEventListener('click', () => (chatPanel.hidden ? abrir() : cerrar()));
    chatCerrar?.addEventListener('click', cerrar);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !chatPanel.hidden) cerrar();
    });

    // Burbujita de saludo: aparece a los segundos, una vez por sesión
    const saludoBurbuja = document.getElementById('chat-saludo');
    const YA_SALUDADO = 'pabilo-chat-saludado';
    const ocultarSaludo = () => saludoBurbuja?.setAttribute('hidden', '');
    if (saludoBurbuja && !sessionStorage.getItem(YA_SALUDADO)) {
      window.setTimeout(() => {
        if (chatPanel.hidden && !sessionStorage.getItem(YA_SALUDADO)) {
          saludoBurbuja.hidden = false;
          sessionStorage.setItem(YA_SALUDADO, '1');
          window.setTimeout(ocultarSaludo, 14000);
        }
      }, 6000);
      saludoBurbuja.addEventListener('click', () => {
        ocultarSaludo();
        abrir();
      });
    }
    chatBoton.addEventListener('click', ocultarSaludo);

    const enviar = async (texto: string) => {
      const limpio = texto.trim();
      if (!limpio || esperando) return;
      esperando = true;
      historial.push({ rol: 'usuario', texto: limpio });
      pintar('usuario', limpio);
      chatInput.value = '';
      chatChips?.setAttribute('hidden', '');

      const escribiendo = pintar('bot', '…');
      escribiendo.classList.add('chat__burbuja--escribiendo');

      try {
        const r = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ mensajes: historial.slice(-8) }),
        });
        if (!r.ok) throw new Error('respuesta no ok');
        const datos = await r.json();
        const respuesta =
          typeof datos.respuesta === 'string' && datos.respuesta
            ? datos.respuesta
            : 'No te he entendido bien, ¿me lo preguntas de otra forma?';
        historial.push({ rol: 'bot', texto: respuesta });
        escribiendo.classList.remove('chat__burbuja--escribiendo');
        escribiendo.textContent = respuesta;
      } catch {
        escribiendo.classList.remove('chat__burbuja--escribiendo');
        escribiendo.textContent =
          'Ahora mismo no puedo responder 😅 Escríbenos por WhatsApp (el botón verde) y te atendemos al momento.';
      } finally {
        esperando = false;
        chatMensajes.scrollTop = chatMensajes.scrollHeight;
      }
    };

    chatForm.addEventListener('submit', (e) => {
      e.preventDefault();
      enviar(chatInput.value);
    });
    chatChips?.querySelectorAll('[data-chip]').forEach((chip) => {
      chip.addEventListener('click', () => enviar(chip.textContent || ''));
    });
  }

  // Sombra sutil en el nav al desplazar
  const nav = document.getElementById('nav');
  const onScroll = () => nav?.classList.toggle('desplazado', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Aparición suave de los elementos .reveal
  const items = document.querySelectorAll('.reveal');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    items.forEach((el) => io.observe(el));
  } else {
    items.forEach((el) => el.classList.add('visible'));
  }
</script>
